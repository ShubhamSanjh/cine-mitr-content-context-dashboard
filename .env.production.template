# ========================================
# Content-Dashboard — Production Settings Template
# ========================================
# 1. Copy this file to .env.production
# 2. Fill in actual values
# 3. NEVER commit secrets to version control

# --- Application ---
APP_ENV=production
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4
SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://cd_user:REPLACE_PASSWORD@db:5432/content_dashboard
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_ECHO=false

# --- CORS ---
# Comma-separated allowed origins — set to your actual domain(s)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- Logging ---
LOG_LEVEL=WARNING

# --- PostgreSQL Container (used by docker-compose) ---
POSTGRES_USER=cd_user
POSTGRES_PASSWORD=REPLACE_PASSWORD
POSTGRES_DB=content_dashboard

