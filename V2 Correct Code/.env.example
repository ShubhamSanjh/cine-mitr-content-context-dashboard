# ============================================
# Content-Dashboard — Environment Variables Template
# Copy to .env.development / .env.staging / .env.production
# ============================================
APP_NAME=Content-Dashboard
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

DATABASE_URL=sqlite:///./content_dashboard.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/content_dashboard
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

CORS_ORIGINS=*
LOG_LEVEL=INFO
API_PREFIX=/api/v1
